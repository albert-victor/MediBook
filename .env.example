# Application
APP_NAME="Medical Appointment and Reminder System"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# Server
HOST=127.0.0.1
PORT=8000

# Database (SQLite by default - swap for MySQL in production)
DATABASE_URL=sqlite:///./data/appointment.db

# MySQL example (future):
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/appointment_db

# Authentication (session-based, no JWT)
SESSION_MAX_AGE=1209600

# Legacy JWT settings (unused - reserved for future API tokens)
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# ALGORITHM=HS256

# Scheduler / reminders
REMINDER_CHECK_INTERVAL_MINUTES=15
REMINDER_HOURS_BEFORE=24
REMINDER_FOLLOWUP_HOURS_BEFORE=2
REMINDER_ENABLED=true

# Email (optional - reminders are simulated when SMTP is not configured)
EMAIL_REMINDERS_ENABLED=true
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@medcare.com

# SMS - KilaKona (https://messaging.kilakona.co.tz/api-documentation)
# Required: SMS_API_URL, SMS_API_KEY, SMS_API_SECRET, SMS_SENDER_ID
SMS_REMINDERS_ENABLED=true
SMS_API_URL=https://messaging.kilakona.co.tz/api/v1/vendor/message/send
SMS_API_KEY=BrayceDominic
SMS_API_SECRET=e3Ub8X5J8sn63kxhu2Zi
SMS_SENDER_ID=
# Included in body always; leave empty on localhost
SMS_DELIVERY_REPORT_URL=
# Default SMS language when patient has no saved preference (sw | en)
SMS_DEFAULT_LANGUAGE=sw
# Instant SMS on successful payment (1 SMS = payment + confirmation)
SMS_PAYMENT_ENABLED=true
# SMS when doctor clicks Approve (1 credit)
SMS_DOCTOR_CONFIRM_ENABLED=true
# Day-before reminder SMS (keep true). 2h follow-up SMS burns extra credits.
SMS_REMINDERS_ENABLED=true
SMS_REMINDER_FOLLOWUP_ENABLED=false
